{{template "layout" .}}

{{define "head"}}
<title>Article not found</title>
<style>
  main {
    display: grid;
    place-content: center;
    translate: 0 -5rem;

    h1 {
      font-size: 8rem;
      color: var(--sec);
      text-align: center;
    }

    h3 {
      text-align: center;
      font-style: italic;
    }
  }
</style>
{{ end }}

{{define "content"}}
<h1>404</h1>
<h3>The article you are looking for doesn't exist or may have been deleted</h3>
{{ end }}
